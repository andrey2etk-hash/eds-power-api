# Supabase (Stage 8A snapshot persistence — server-side only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Auth session environment (names/placeholders only; never commit real values)
# EDS_SESSION_HMAC_SECRET must be configured in Render/local env; never commit real value.
# AUTH_SESSION_TTL_HOURS is required for auth session creation. Recommended MVP value: 12.
EDS_SESSION_HMAC_SECRET=
AUTH_SESSION_TTL_HOURS=12

# Optional: Module 01 login stdout diagnostics (prefix EDS_POWER_AUTH_LOGIN_DIAG). Default off.
# Truthy: 1, true, yes, on. Omit or false in production.
# EDS_POWER_AUTH_DEBUG_LOGS=
